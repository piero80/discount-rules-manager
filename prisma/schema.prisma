// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Session table (già presente in Shopify template)
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

// Multiple Discount Rules - Regole specifiche per discount
model DiscountSpecificRule {
  id            String   @id @default(cuid())
  shop          String
  discountId    String // Shopify discount ID/GID
  discountTitle String // Cache del titolo per UI
  discountType  String // "DiscountCodeBasic", "DiscountAutomaticBasic", etc.
  mode          String   @default("exclude") // "exclude" o "include"
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  excludedCollections SpecificExcludedCollection[]
  excludedProducts    SpecificExcludedProduct[]

  @@unique([shop, discountId])
  @@index([shop, active])
  @@index([discountId])
}

// Collections escluse per regole specifiche
model SpecificExcludedCollection {
  id            String @id @default(cuid())
  collectionId  String // Shopify collection GID
  title         String
  productsCount Int    @default(0)

  ruleId String
  rule   DiscountSpecificRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([ruleId, collectionId])
  @@index([ruleId])
}

// Prodotti esclusi per regole specifiche
model SpecificExcludedProduct {
  id        String @id @default(cuid())
  productId String // Shopify product GID
  title     String

  ruleId String
  rule   DiscountSpecificRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([ruleId, productId])
  @@index([ruleId])
}

// Opzionale: Log delle azioni per analytics
model RuleLog {
  id        String   @id @default(cuid())
  shop      String
  action    String // "created", "updated", "deleted"
  ruleId    String?
  metadata  String? // JSON stringified
  createdAt DateTime @default(now())

  @@index([shop])
  @@index([createdAt])
}
