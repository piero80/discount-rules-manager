// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Session table (già presente in Shopify template)
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

// Subscription management - Optimized for App Store
model Subscription {
  id                 String    @id @default(cuid())
  shop               String    @unique
  planName           String    @default("FREE") // "FREE", "STARTER", "PROFESSIONAL", "ENTERPRISE"
  status             String    @default("ACTIVE") // "ACTIVE", "CANCELED", "TRIAL"
  maxRules           Int       @default(1) // Updated default for FREE plan
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  trialEndsAt        DateTime?
  shopifyChargeId    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([shop])
}

// Multiple Global Discount Rules - Basic Plan feature
model DiscountRule {
  id          String  @id @default(cuid())
  shop        String
  name        String  @default("Rule")
  description String?
  mode        String  @default("exclude") // "exclude" o "include"
  active      Boolean @default(true)
  priority    Int     @default(0) // 0 = highest priority

  // Basic Plan - Scheduling fields
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  isScheduled    Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  excludedCollections ExcludedCollection[]
  excludedProducts    ExcludedProduct[]

  // Multiple rules allowed per shop (removed unique constraint)
  @@index([shop, active])
  @@index([shop, priority])
  @@index([scheduledStart, scheduledEnd])
}

// Collections escluse dalle regole
model ExcludedCollection {
  id            String @id @default(cuid())
  collectionId  String // Shopify collection GID
  title         String
  productsCount Int    @default(0)

  // Relation to rule
  ruleId String
  rule   DiscountRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([ruleId, collectionId])
  @@index([ruleId])
}

// Products esclusi dalle regole
model ExcludedProduct {
  id        String  @id @default(cuid())
  productId String // Shopify product GID
  title     String
  handle    String? // product handle for easier identification
  imageUrl  String? // product image URL for UI display

  // Relation to rule
  ruleId String
  rule   DiscountRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([ruleId, productId])
  @@index([ruleId])
}

// Opzionale: Log delle azioni per analytics
model RuleLog {
  id        String   @id @default(cuid())
  shop      String
  action    String // "created", "updated", "deleted"
  ruleId    String?
  metadata  String? // JSON stringified
  createdAt DateTime @default(now())

  @@index([shop])
  @@index([createdAt])
}
